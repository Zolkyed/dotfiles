{
    "bootloader_config": {
        "bootloader": "Grub",
        "removable": true,
        "uki": false
    },
    "hostname": "archlinux",
    "kernels": [
        "linux"
    ],
    "locale_config": {
        "kb_layout": "us",
        "sys_enc": "UTF-8",
        "sys_lang": "en_US.UTF-8"
    },
    "mirror_config": {
        "mirror_regions": {
            "Canada": [],
            "United States": []
        }
    },
    "network_config": {
        "type": "nm"
    },
    "packages": [
        "btrfs-progs",
        "curl",
        "efibootmgr",
        "git",
        "grub",
        "networkmanager",
        "openssh",
        "sudo"
    ],
    "pacman_config": {
        "color": true,
        "parallel_downloads": 5
    },
    "profile_config": {
        "profile": {
            "main": "Minimal"
        }
    },
    "services": [
        "NetworkManager.service",
        "sshd.service"
    ],
    "swap": {
        "algorithm": "zstd",
        "enabled": true
    },
    "timezone": "America/Toronto",
    "version": "4.3"
}