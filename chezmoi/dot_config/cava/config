## Configuration file for CAVA - Catppuccin Mocha Theme

[general]
framerate = 60
autosens = 1
sensitivity = 100
bars = 15
bar_width = 2
bar_spacing = 1
lower_cutoff_freq = 50
higher_cutoff_freq = 10000

[input]
# Audio capturing method. Possible methods are:
# 'pulse', 'alsa', 'fifo', 'sndio', 'jack' or 'portaudio'.
# Default method is 'pulse'.
method = pulse
source = auto

[output]
method = ncurses
channels = stereo
mono_option = average
reverse = 0
raw_target = /dev/stdout
data_format = binary
bar_delimiter = 59
frame_delimiter = 10

[color]
# Catppuccin Mocha background
background = default
# Catppuccin Mocha mauve foreground for high contrast
foreground = '#cba6f7'

# Catppuccin Mocha gradient - vibrant purples and blues
gradient = 1
gradient_count = 6
gradient_color_1 = '#89b4fa'  # catppuccin blue
gradient_color_2 = '#89dceb'  # catppuccin sky  
gradient_color_3 = '#74c7ec'  # catppuccin sapphire
gradient_color_4 = '#cba6f7'  # catppuccin mauve
gradient_color_5 = '#f5c2e7'  # catppuccin pink
gradient_color_6 = '#f38ba8'  # catppuccin red

[smoothing]
monstercat = 0
waves = 0
noise_reduction = 77

[eq]
1 = 1.0
2 = 1.0
3 = 1.0
4 = 1.0
5 = 1.0
