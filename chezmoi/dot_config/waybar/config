{
    "output": "DP-2",
    "layer": "top",
    "position": "top",
    "height": 38,
    "spacing": 10,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "tray",
        "custom/spotify",
        "custom/updates",
        "disk",
        "custom/weather",
        "pulseaudio",
        "network",
        "custom/mullvad"
    ],

    "hyprland/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "{name}",
        "show-special": false,
        "persistent-workspaces": {
        }
    },

    "hyprland/window": {
        "format": "{title}",
        "max-length": 50,
        "rewrite": {
            "(.*) — Mozilla Firefox": "󰈹 $1",
            "(.*) - Visual Studio Code": "󰨞 $1",
            "(.*) - Spotify": "󰓇 $1",
            "kitty": "󰄛 Terminal"
        }
    },

    "clock": {
        "format": "{:%a %b %d  %H:%M}",
        "format-alt": "{:%Y-%m-%d %H:%M:%S}",
        "tooltip-format": "<big>{:%B %Y}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1,
        "on-click-right": "gnome-calendar"
    },

    "disk": {
        "format": "<b>HOME:</b> {percentage_used}%",
        "path": "/home",
        "tooltip-format": "Home: {used} / {total}\nFree: {free} ({percentage_free}%)",
        "interval": 30,
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "format-wifi": "<b>NET:</b> {signalStrength}%",
        "format-ethernet": "<b>NET:</b> {ipaddr}",
        "format-disconnected": "<b>NET:</b> DC",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n󰇚 {bandwidthDownBits} 󰕒 {bandwidthUpBits}\nIP: {ipaddr}",
        "tooltip-format-ethernet": "{ifname}: {ipaddr}/{cidr}\n󰇚 {bandwidthDownBits} 󰕒 {bandwidthUpBits}",
        "tooltip-format-disconnected": "Disconnected",
        "interval": 2,
        "on-click": "kitty nmtui"
    },

    "pulseaudio": {
        "format": "<b>VOL:</b> {volume}%",
        "format-muted": "󰖁 Muted",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋎",
            "headset": "󰋎",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "on-click-right": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "tooltip-format": "Volume: {volume}%"
    },

    "tray": {
        "icon-size": 18,
        "spacing": 8
    },

    "custom/updates": {
        "format": "󰚰 {}",
        "interval": 3600,
        "exec": "checkupdates 2>/dev/null | wc -l",
        "exec-if": "[ $(checkupdates 2>/dev/null | wc -l) -gt 0 ]",
        "on-click": "kitty --hold yay -Syu",
        "tooltip-format": "{} updates available\nClick to update"
    },

    "custom/weather": {
        "format": "{}",
        "interval": 1800,
        "exec": "curl -s 'wttr.in/YWLM?format=%c+%t' 2>/dev/null || echo '󰖐 --'",
        "tooltip": false
    },

    "custom/mullvad": {
        "return-type": "json",
        "exec": "python3 ~/.config/waybar/scripts/mullvad_control.py",
        "on-click": "python3 ~/.config/waybar/scripts/mullvad_control.py toggle && sleep 0.5 && pkill -RTMIN+8 waybar",
        "on-click-right": "~/.config/waybar/scripts/mullvad_menu.sh",
        "interval": 1,
        "tooltip": true,
        "signal": 8
    }
}
