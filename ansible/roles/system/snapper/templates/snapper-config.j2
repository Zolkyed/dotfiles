# Snapper configuration managed by Ansible
SUBVOLUME="{{ item.filesystem_root }}"
FSTYPE="btrfs"
ALLOW_USERS="{{ item.allow_users | default([]) | join(',') }}"
ALLOW_GROUPS="{{ item.allow_groups | default([]) | join(',') }}"
SYNC_ACL="{{ 'yes' if item.sync_acl | default(false) else 'no' }}"
TIMELINE_CREATE="{{ 'yes' if item.timeline_create | default(true) else 'no' }}"
TIMELINE_CLEANUP="{{ 'yes' if item.timeline_cleanup | default(true) else 'no' }}"
NUMBER_CLEANUP="{{ 'yes' if item.number_cleanup | default(true) else 'no' }}"
NUMBER_LIMIT="{{ item.number_limit | default('50') }}"
NUMBER_LIMIT_IMPORTANT="{{ item.number_limit_important | default('10') }}"
TIMELINE_LIMIT_HOURLY="{{ item.timeline_limit_hourly | default('10') }}"
TIMELINE_LIMIT_DAILY="{{ item.timeline_limit_daily | default('7') }}"
TIMELINE_LIMIT_WEEKLY="{{ item.timeline_limit_weekly | default('4') }}"
TIMELINE_LIMIT_MONTHLY="{{ item.timeline_limit_monthly | default('6') }}"
TIMELINE_LIMIT_YEARLY="{{ item.timeline_limit_yearly | default('1') }}"
