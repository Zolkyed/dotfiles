#!/usr/bin/env bash
set -euo pipefail

remote="${KONSAVE_RCLONE_REMOTE:-gdrive}"
path="${KONSAVE_RCLONE_PATH:-konsave}"
import_dir="${KONSAVE_IMPORT_DIR:-/tmp/konsave_import}"
export_dir="${KONSAVE_EXPORT_DIR:-/tmp/konsave_export}"

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    printf 'Missing required command: %s\n' "$1" >&2
    exit 1
  fi
}

usage() {
  cat <<EOF
Usage:
  konsave-list
  konsave-import [profile]
  konsave-export [profile]
  konsave-remove [profile]

  konsavectl list
  konsavectl import [profile]
  konsavectl export [profile]
  konsavectl remove [profile]

Environment:
  KONSAVE_RCLONE_REMOTE  rclone remote name, default: gdrive
  KONSAVE_RCLONE_PATH    remote folder path, default: konsave
  KONSAVE_IMPORT_DIR     temporary import directory, default: /tmp/konsave_import
  KONSAVE_EXPORT_DIR     temporary export directory, default: /tmp/konsave_export
EOF
}

list_profiles() {
  require_cmd rclone

  rclone lsf "${remote}:${path}/" --files-only |
    sed -n 's/\.knsv$//p' |
    sort
}

prompt_profile() {
  local prompt="$1"

  printf 'Available konsave profiles:\n'
  list_profiles
  printf '\n%s: ' "$prompt"
  read -r profile
}

validate_profile() {
  profile="${profile%.knsv}"

  if [[ -z "$profile" ]]; then
    printf 'Profile name cannot be empty\n' >&2
    exit 1
  fi

  if [[ "$profile" == */* ]]; then
    printf 'Profile name cannot contain /\n' >&2
    exit 1
  fi
}

cmd_list() {
  list_profiles
}

local_profile_exists() {
  konsave -l |
    sed -E 's/^[[:space:]*-]+//; s/[[:space:]]+$//' |
    grep -Fxq "$profile"
}

cmd_import() {
  require_cmd rclone
  require_cmd konsave

  profile="${1:-}"
  if [[ -z "$profile" ]]; then
    prompt_profile "Profile to import"
  fi
  validate_profile

  local archive="${import_dir}/${profile}.knsv"
  cleanup_import() {
    rm -rf "$import_dir"
  }
  trap cleanup_import EXIT

  mkdir -p "$import_dir"
  chmod 700 "$import_dir"

  rclone copy --checksum --progress "${remote}:${path}/${profile}.knsv" "$import_dir/"

  if local_profile_exists; then
    konsave -r "$profile"
  fi

  konsave -i "$archive" -f
  konsave -a "$profile"
}

cmd_export() {
  require_cmd rclone
  require_cmd konsave

  profile="${1:-}"
  if [[ -z "$profile" ]]; then
    printf 'Profile name to export: '
    read -r profile
  fi
  validate_profile

  cleanup_export() {
    rm -rf "$export_dir"
  }
  trap cleanup_export EXIT

  mkdir -p "$export_dir"
  chmod 700 "$export_dir"

  konsave -s "$profile"
  konsave -e "$profile" -d "$export_dir"
  rclone copy --progress "${export_dir}/${profile}.knsv" "${remote}:${path}/"
}

cmd_remove() {
  require_cmd rclone

  profile="${1:-}"
  if [[ -z "$profile" ]]; then
    prompt_profile "Profile to remove"
  fi
  validate_profile

  printf "Delete '%s.knsv' from %s:%s/? Type 'yes' to confirm: " "$profile" "$remote" "$path"
  read -r confirm

  if [[ "$confirm" != "yes" ]]; then
    printf 'Deletion cancelled\n' >&2
    exit 1
  fi

  rclone delete "${remote}:${path}/${profile}.knsv"
}

command_from_name() {
  case "$(basename "$0")" in
    konsave-list) printf 'list' ;;
    konsave-import) printf 'import' ;;
    konsave-export) printf 'export' ;;
    konsave-remove) printf 'remove' ;;
    konsavectl) printf '%s' "${1:-}" ;;
    *)
      printf 'Unknown command name: %s\n' "$(basename "$0")" >&2
      exit 1
      ;;
  esac
}

main() {
  local command
  command="$(command_from_name "${1:-}")"

  if [[ "$command" == "-h" || "$command" == "--help" || -z "$command" ]]; then
    usage
    exit 0
  fi

  if [[ "$(basename "$0")" == "konsavectl" ]]; then
    shift || true
  fi

  case "$command" in
    list) cmd_list "$@" ;;
    import) cmd_import "$@" ;;
    export) cmd_export "$@" ;;
    remove | delete) cmd_remove "$@" ;;
    *)
      usage >&2
      exit 1
      ;;
  esac
}

main "$@"