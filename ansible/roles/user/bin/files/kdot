#!/usr/bin/env bash
# kdot — KDE profile manager for your dotfiles repo
# Usage:
#   kdot --export [profile]   Save + export with today's date as a .knsv archive
#   kdot --import [profile]   Import the latest .knsv archive for that profile
#   kdot --list               List tracked archives and installed konsave profiles
#   kdot --push               Git-add new .knsv files, commit, and push
#
# Set DOTFILES_DIR to override the default repo location.
set -euo pipefail

DOTFILES_DIR="${DOTFILES_DIR:-$HOME/projects/dotfiles}"
PROFILES_DIR="$DOTFILES_DIR/kde/konsave"
PROFILE="${2:-default}"
DATE="$(date +%Y-%m-%d)"

_require_konsave() {
  if ! command -v konsave >/dev/null 2>&1; then
    echo "Error: konsave is not installed (pipx install konsave)." >&2
    exit 1
  fi
}

_require_profiles_dir() {
  if [[ ! -d "$PROFILES_DIR" ]]; then
    echo "Error: profiles directory not found: $PROFILES_DIR" >&2
    echo "Set DOTFILES_DIR or check your repo path." >&2
    exit 1
  fi
}

cmd_export() {
  _require_konsave
  _require_profiles_dir
  local archive_name="${PROFILE}_${DATE}"
  konsave -s "$PROFILE" -f
  konsave -e "$PROFILE" -d "$PROFILES_DIR" -n "$archive_name" -f
  echo "Exported: $PROFILES_DIR/$archive_name.knsv"
}

cmd_import() {
  _require_konsave
  _require_profiles_dir
  # Find the latest archive for the given profile name
  local archive
  archive="$(ls -t "$PROFILES_DIR/${PROFILE}"*.knsv 2>/dev/null | head -1 || true)"
  if [[ -z "$archive" ]]; then
    echo "Error: no .knsv archive found for profile '$PROFILE' in $PROFILES_DIR" >&2
    echo "Available archives:" >&2
    ls "$PROFILES_DIR"/*.knsv 2>/dev/null || echo "  (none)" >&2
    exit 1
  fi
  echo "Importing: $archive"
  konsave -i "$archive"
  echo "Done. You may need to log out and back in for all changes to take effect."
}

cmd_list() {
  _require_profiles_dir
  echo "Tracked archives in $PROFILES_DIR:"
  local found=false
  while IFS= read -r f; do
    echo "  $(basename "$f")"
    found=true
  done < <(find "$PROFILES_DIR" -maxdepth 1 -name "*.knsv" | sort)
  [[ "$found" == true ]] || echo "  (none)"

  if command -v konsave >/dev/null 2>&1; then
    echo
    echo "Installed konsave profiles:"
    konsave -l
  fi
}

cmd_push() {
  _require_profiles_dir
  cd "$DOTFILES_DIR"

  # Collect only new/modified .knsv files
  local files
  files="$(git status --porcelain "kde/konsave/" 2>/dev/null \
    | grep '\.knsv' | awk '{print $2}')"

  if [[ -z "$files" ]]; then
    echo "Nothing to push — no new or modified .knsv files."
    exit 0
  fi

  echo "Staging:"
  echo "$files" | sed 's/^/  /'
  # shellcheck disable=SC2086
  git add $files
  git commit -m "chore(konsave): export ${DATE}"
  git push
}

case "${1:-}" in
  --export) cmd_export ;;
  --import) cmd_import ;;
  --list)   cmd_list   ;;
  --push)   cmd_push   ;;
  *)
    echo "Usage:"
    echo "  kdot --export [profile]   export with today's date (default: default)"
    echo "  kdot --import [profile]   import latest archive for profile"
    echo "  kdot --list               list tracked archives + konsave profiles"
    echo "  kdot --push               git push new .knsv files to remote"
    echo
    echo "Env: DOTFILES_DIR (default: \$HOME/projects/dotfiles)"
    exit 1
    ;;
esac
