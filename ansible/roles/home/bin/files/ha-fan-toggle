#!/usr/bin/env python3

import os
import sys
import json
import urllib.request
import urllib.error
from pathlib import Path

try:
    import yaml
except ImportError:
    print("Missing dependency: pyyaml (pip install pyyaml)", file=sys.stderr)
    sys.exit(1)


CONFIG_PATH = Path.home() / ".config/homectl/config.yml"


def load_config():
    if not CONFIG_PATH.exists():
        print(f"Config not found: {CONFIG_PATH}", file=sys.stderr)
        sys.exit(1)

    with open(CONFIG_PATH, "r") as f:
        return yaml.safe_load(f)


def get_env(name: str) -> str:
    value = os.environ.get(name)
    if not value:
        print(f"Missing env var: {name}", file=sys.stderr)
        sys.exit(1)
    return value


def api_url(base_url: str, path: str) -> str:
    return f"{base_url.rstrip('/')}/api{path}"


def get_state(base_url: str, token: str, entity_id: str) -> str:
    url = api_url(base_url, f"/states/{entity_id}")
    req = urllib.request.Request(url, headers={"Authorization": f"Bearer {token}"})

    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())["state"]


def call_service(base_url: str, token: str, domain: str, service: str, entity_id: str):
    url = api_url(base_url, f"/services/{domain}/{service}")

    payload = json.dumps({"entity_id": entity_id}).encode()

    req = urllib.request.Request(
        url,
        data=payload,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
        },
        method="POST",
    )

    urllib.request.urlopen(req)


def resolve_entity(config, name: str) -> str:
    mapping = {
        "fan": config["entityIDFan"],
        "light": config["entityIDLight"],
    }

    if name not in mapping:
        print(f"Unknown target: {name} (use: fan|light)", file=sys.stderr)
        sys.exit(1)

    return mapping[name]


def main():
    config = load_config()

    ha_url = config["baseUrl"]
    ha_token = get_env("HA_TOKEN")

    target = sys.argv[1] if len(sys.argv) > 1 else "fan"
    entity_id = resolve_entity(config, target)

    try:
        state = get_state(ha_url, ha_token, entity_id)
        service = "turn_off" if state == "on" else "turn_on"

        call_service(ha_url, ha_token, "switch", service, entity_id)

        print(f"{entity_id}: {state} → {'off' if state == 'on' else 'on'}")

    except urllib.error.URLError as e:
        print(f"Request failed: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()