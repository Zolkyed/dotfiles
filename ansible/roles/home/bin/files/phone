#!/usr/bin/env python3
"""Phone utilities — battery check and webhook trigger via local network."""

import sys
import urllib.request
import urllib.error


def send_webhook(url: str) -> None:
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req):
        pass


def get_battery(url: str) -> None:
    req = urllib.request.Request(url)
    with urllib.request.urlopen(req) as resp:
        battery = resp.read().decode().strip()
    import subprocess
    subprocess.run(["notify-send", "Phone Battery", f"{battery}%", "--icon=battery"])


def usage() -> None:
    print("Usage:")
    print("  phone battery <url>")
    print("  phone webhook <url>")
    sys.exit(1)


def main() -> None:
    if len(sys.argv) < 3:
        usage()

    command = sys.argv[1]
    url = sys.argv[2]

    try:
        if command == "battery":
            get_battery(url)
        elif command == "webhook":
            send_webhook(url)
        else:
            usage()
    except urllib.error.URLError as e:
        print(f"Error: {e}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
